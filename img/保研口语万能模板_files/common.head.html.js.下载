function isChinese() {
  if (/lang=en/.test(window.location.search)) {
    return false;
  }
  return navigator.language === "zh-CN" || navigator.language === "zh";
}

function translate(text) {
  if (isChinese()) return text;
  return dict[text] || text;
}

function write(text, t) {
  t = t || true;
  document.write(t ? translate(text) : text);
}

window.$toast = function (str, noWrap, center) {
  var el = $("<div>" + str + "</div>");

  el.css({
    backgroundColor: "rgba(0, 0, 0, .7)",
    color: "#fff",
    position: "fixed",
    zIndex: "999",
    top: "50%",
    left: "50%",
    transform: "translate(-50%, -50%)",
    padding: "8px 12px",
    fontSize: "14px",
    borderRadius: "2px",
    transition: ".4s ease",
    opacity: "0",
  });

  if (noWrap) {
    el.css("white-space", "nowrap");
  }

  if (center) {
    el.css("text-align", "center");
  }

  $("body").append(el);

  setTimeout(function () {
    el.css("opacity", "1");
  });

  setTimeout(function () {
    el.css("opacity", "0");

    setTimeout(function () {
      el.remove();
    }, 400);
  }, 3500);
};

window.$modal = function (title, content, okText) {
  var el = $(
    [
      '<div class="__modal-wrap" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, .6); z-index: 100;">',
      '<div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; border-radius: 4px; background: white; width: 290px;">',
      '<div style="text-align: center; padding: 24px 16px; padding-bottom: 0; font-size: 16px; font-weight: 700;">',
      title,
      "</div>",
      '<div style="padding: 24px 16px; padding-top: 12px; font-size: 14px;text-align: center;">',
      content,
      "</div>",
      '<div class="__modal-ok" style="border-top: 1px solid rgba(120, 130, 140, 0.13); height: 52px; text-align: center; color: #4caf50; font-weight: 700; line-height: 52px; font-size: 14px;">',
      okText,
      "</div>",
      "</div>",
      "</div>",
    ].join("")
  );

  $("body").append(el);

  el.find(".__modal-ok").click(function () {
    el.remove();
  });

  el.click(function (e) {
    if ($(e.target).hasClass("__modal-wrap")) {
      el.remove();
    }
  });
};

(function () {
  function handleFontSize() {
    WeixinJSBridge.invoke("setFontSizeCallback&", { fontSize: 0 });
    WeixinJSBridge.on("menu:setfont", function () {
      WeixinJSBridge.invoke("setFontSizeCallback", { "fontSize&": 0 });
    });
  }
  if (
    typeof WeixinJSBridge == "object" &&
    typeof WeixinJSBridge.invoke == "function"
  ) {
    handleFontSize();
  } else {
    document.addEventListener("WeixinJSBridgeReady", handleFontSize, false);
  }
})();

// 禁止分享和下载
document.addEventListener('DOMContentLoaded', function () {
  function hideMenuItems() {
    var queries = (function() {
      var search = window.location.search.split('?')[1].split('&');
      var queries = {};
      search.forEach(function(item) {
        var [key, value] = item.split('=');
        queries[key] = value;
      });
      return queries;
    })();
    if (+queries.show_share !== 1) {
      wx.hideMenuItems({
        menuList: [
          'menuItem:share:appMessage',
          'menuItem:share:wechat',
          'menuItem:share:timeline',
          'menuItem:share:qq',
          'menuItem:share:weiboApp',
          'menuItem:share:facebook',
          'menuItem:share:QZone',
        ],
      });
    }
    if (+queries.download !== 1) {
      wx.hideMenuItems({
        menuList: [
          "menuItem:copyUrl",
          "menuItem:openWithSafari",
          "menuItem:originPage",
          'menuItem:favorite',
        ]
      });
    }
  }
  wx.ready(function() {
    hideMenuItems();
  });
});
